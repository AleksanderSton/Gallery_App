extends layout

block content
  h2(class='fw-semibold mb-4') 🔍 #{title}

  div(class='row g-4')
    each gallery in galleries
      div(class='col-md-4 mb-3')
        div(class='card shadow-sm border-0 h-100')
          
          div(style='height: 200px; overflow: hidden; background-color: #e9ecef;')
            if gallery.highlightImage
              img(src='/images/' + gallery.highlightImage alt='Miniaturka galerii' class='w-100 h-100' style='object-fit: cover;')
            else
              div(class='w-100 h-100 d-flex flex-column align-items-center justify-content-center text-muted')
                span(class='fs-2 mb-1') 📷
                span Brak zdjęć
                
          div(class='card-body d-flex flex-column')
            h5(class='card-title fw-semibold') #{gallery.name}
            
            p(class='card-text small text-muted mb-2') Autor: #{gallery.owner ? gallery.owner.username : 'Nieznany'}
            
            if gallery.description
              p(class='card-text small mb-4') #{gallery.description}

            div(class='mt-auto d-flex flex-wrap gap-2')
              a(href='/galleries/gallery_show?gallery_id=' + gallery._id class='btn btn-sm btn-primary text-white flex-grow-1') 👁️ Obejrzyj galerię
              
              if loggedUser && (loggedUser === 'admin' || (gallery.owner && gallery.owner.username === loggedUser))
                a(href='/galleries/gallery_update?gallery_id=' + gallery._id class='btn btn-sm btn-warning') ✏️ Edytuj
                a(href='/galleries/gallery_delete?gallery_id=' + gallery._id class='btn btn-sm btn-danger') 🗑️ Usuń
                
    else
      div(class='col-12')
        div(class='alert alert-info') Brak dostępnych galerii do wyświetlenia.