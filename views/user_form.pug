extends layout

block content
  div(class='row justify-content-center mt-4')
    div(class='col-md-5')
      div(class='card shadow-sm border-0')
        div(class='card-body p-4')
          h2(class='card-title fw-semibold mb-4') 👤 #{title}

          form(method='POST')
            div(class='mb-3')
              label(for='first_name' class='form-label') First Name
              input#first_name(type='text' class='form-control' placeholder='min. 2 litery' name='first_name' required value=(undefined==user ? '' : user.first_name))
            div(class='mb-3')
              label(for='last_name' class='form-label') Last Name
              input#last_name(type='text' class='form-control' placeholder='min. 2 litery' name='last_name' required value=(undefined==user ? '' : user.last_name))
            div(class='mb-3')
              label(for='username' class='form-label') Username
              input#username(type='text' class='form-control' placeholder='min. 3 litery' name='username' required value=(undefined==user ? '' : user.username))
            div(class='mb-3')
              label(for='password' class='form-label') Password
              input#password(type='password' class='form-control' placeholder='min. 8 znaków' name='password' minlength='8' autocomplete='off' required value='')
            button(type='submit' class='btn btn-primary w-100') Zapisz

          if messages
            div(class='mt-3')
              each message in messages
                div(class='alert alert-danger py-1 small') !{message}