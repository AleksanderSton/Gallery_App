extends layout

block content
  div(class='row justify-content-center mt-4')
    div(class='col-md-5')
      div(class='card shadow-sm border-0')
        div(class='card-body p-4')
          h2(class='card-title fw-semibold mb-4') 🗂️ #{title}

          form(method='POST')
            div(class='mb-3')
              label(for='g_name' class='form-label') Nazwa galerii:
              input#g_name(type='text' class='form-control' placeholder='min. 2 znaki' name='g_name' required value=(undefined==gallery ? '' : gallery.name))
            div(class='mb-3')
              label(for='g_description' class='form-label') Opis:
              input#g_description(type='text' class='form-control' placeholder='min. 2 znaki' name='g_description' required value=(undefined==gallery ? '' : gallery.description))
            div(class='mb-3')
              label(for='g_user' class='form-label') Właściciel:
              select#g_user(class='form-select' name='g_user' required)
                option(value='') -- Wybierz właściciela --
                each user in users
                  if gallery
                    if user._id.toString() === gallery.owner._id.toString()
                      option(value=user._id selected) #{user.first_name} #{user.last_name}
                    else
                      option(value=user._id) #{user.first_name} #{user.last_name}
                  else
                    option(value=user._id) #{user.first_name} #{user.last_name}
            button(type='submit' class='btn btn-primary w-100') Zapisz

          if messages
            div(class='mt-3')
              each message in messages
                div(class='alert alert-danger py-2 small mb-1') !{message}