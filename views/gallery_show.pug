extends layout

block content
  div(class='d-flex justify-content-between align-items-center mb-4')
    h2(class='fw-semibold m-0') 📂 #{title}
    a(href='/galleries/gallery_browse' class='btn btn-outline-secondary') ⬅️ Powrót do przeglądania

  if gallery.description
    p(class='text-muted mb-4') #{gallery.description}

  if images && images.length > 0
    div(class='row g-4')
      each img in images
        div(class='col-md-3')
          div(class='card shadow-sm border-0 h-100')
            div(style='height: 200px; overflow: hidden; background-color: #f8f9fa;')
              img(src='/images/' + img.path alt=img.name class='w-100 h-100' style='object-fit: cover;')
            
            div(class='card-body d-flex flex-column')
              h6(class='card-title fw-semibold') #{img.name}
              if img.description
                p(class='card-text small text-muted mb-3') #{img.description}
              
              div(class='mt-auto d-flex gap-1')
                a(href='/images/image_show?image_id=' + img._id class='btn btn-sm btn-info text-white flex-grow-1') Zobacz
                
                //- Edycja/Usuwanie pokazujemy tylko autorowi galerii lub adminowi
                if loggedUser && (loggedUser === 'admin' || (gallery.owner && gallery.owner.username === loggedUser))
                  a(href='/images/image_update?image_id=' + img._id + '&gallery_id=' + gallery._id class='btn btn-sm btn-warning') ✏️
                  a(href='/images/image_delete?image_id=' + img._id class='btn btn-sm btn-danger') 🗑️
  else
    div(class='alert alert-light border')
      p(class='text-muted m-0') Ta galeria nie ma jeszcze żadnych zdjęć.